# GCP_PROJECT_ID — ID do seu projeto GCP (ex: my-project-123456)
GCP_PROJECT_ID=

# GCS_BUCKET_NAME — Nome do bucket criado em us-central1
GCS_BUCKET_NAME=briefapp-guardian-metrics

# ADMIN_PASSWORD_HASH — Hash bcrypt da senha do painel admin
# Gerar com: php -r "echo password_hash('SuaSenha', PASSWORD_BCRYPT);"
ADMIN_PASSWORD_HASH=

# TELEGRAM_BOT_TOKEN — Token do bot Telegram para alertas
TELEGRAM_BOT_TOKEN=

# TELEGRAM_CHAT_ID — ID do chat/grupo para receber alertas
TELEGRAM_CHAT_ID=

# Configurações do .NET backend
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8081

# Configurações do PHP frontend
PHP_SESSION_NAME=briefapp_session
